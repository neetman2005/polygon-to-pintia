# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.exe binary
*.zip binary
*.png binary
*.jpg binary
*.ico binary
